# Copy to .env and fill in the values you actually use.
# cp .env.example .env

# Required for gateway auth
OPENCLAW_GATEWAY_TOKEN=replace-me

# Required if you want clone/push/PR automation via GitHub
GH_TOKEN=

# Optional host port for the gateway (container still listens on 18789)
HOST_GATEWAY_PORT=19789

# Optional integrations
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
GOOGLE_API_KEY=

# Optional custom CA bundle on the host.
# Leave unset to use /etc/ssl/certs/ca-certificates.crt.
EXTRA_CA_CERT_PATH=
