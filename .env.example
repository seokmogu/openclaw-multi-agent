# Copy to .env and fill in the values you actually use.
# cp .env.example .env

# Required for gateway auth
OPENCLAW_GATEWAY_TOKEN=replace-me

# Required if you want clone/push/PR automation via GitHub
GH_TOKEN=

# Optional host port for the gateway (container still listens on 18789)
HOST_GATEWAY_PORT=19789

# Git author for OCMA commits (defaults shown)
GIT_AUTHOR_NAME=OCMA Bot
GIT_AUTHOR_EMAIL=ocma-bot@users.noreply.github.com

# Optional integrations
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
GOOGLE_API_KEY=

# LLM API keys — intentionally empty.
# OCMA uses OAuth/session-based auth (auth-profiles.json, ~/.claude, ~/.codex).
# Do NOT set these unless you explicitly want API-key-based billing.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional custom CA bundle on the host.
# Leave unset to use /etc/ssl/certs/ca-certificates.crt.
EXTRA_CA_CERT_PATH=

# ─── Cloud Infrastructure (optional) ────────────────────────────
# AWS: either set role ARN for assume-role, or mount ~/.aws from host
AWS_ROLE_ARN=
AWS_DEFAULT_REGION=ap-northeast-2

# GCP: either set project + mount SA key, or mount ~/.config/gcloud from host
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Vercel: personal or team token
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Supabase: access token + project ref
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Terraform: state backend (optional)
TF_STATE_BUCKET=
