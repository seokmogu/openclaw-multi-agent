.DS_Store

# OpenClaw local runtime/workspace artifacts
workspaces/
workspaces/**/.openclaw/
workspaces/**/.git/

# Local auth material (never commit)
agents/*/auth-profiles.json

# Local gateway/runtime caches
.omc/
tmp/

# Profile-specific runtime cron state snapshots
state/cron_state.*.json

# Docker/Podman secrets (never commit)
.env

# Container runtime config (generated per environment)
container-config/
