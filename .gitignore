.DS_Store

# OpenClaw local runtime/workspace artifacts
workspaces/
workspaces/**/.openclaw/
workspaces/**/.git/

# Gateway auto-generated runtime files per agent
agents/*/.openclaw/
agents/*/BOOTSTRAP.md
agents/*/HEARTBEAT.md
agents/*/IDENTITY.md
agents/*/TOOLS.md
agents/*/USER.md
agents/*/state/

# Exception: orchestrator HEARTBEAT.md contains custom cycle instructions
!agents/orchestrator/HEARTBEAT.md

# Local auth material (never commit)
agents/*/auth-profiles.json

# Local gateway/runtime caches
.omc/
tmp/

# Profile-specific runtime cron state snapshots
state/cron_state.*.json

# Docker/Podman secrets (never commit)
.env

# Container runtime config (generated per environment)
container-config/
